DEPIN_API_KEY=DepinGuard_Local_API_Key_2026_X7m2Q9
JWT_SECRET_KEY=DepinGuard_Local_JWT_Secret_2026_Z4p8R1

# Backend -> AI integration (local default)
AI_SERVICE_URL=http://ai-service:10000/predict
AI_TIMEOUT_SECONDS=4
AI_RETRY_COUNT=1

# Backend CORS
# Comma-separated exact origins (required)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional regex for rotating tunnel domains (example for Cloudflare quick tunnel)
CORS_ALLOWED_ORIGIN_REGEX=^https://.*\.trycloudflare\.com$

# AI service runtime port
PORT=10000
AI_SERVICE_PORT=10000

# Optional auth bootstrap user (leave empty in normal dev)
BOOTSTRAP_ADMIN_USER=
BOOTSTRAP_ADMIN_PASSWORD=

# Frontend (local default)
VITE_API_URL=http://localhost:8000
VITE_AUTH_URL=http://localhost:8001
VITE_API_KEY=DepinGuard_Local_API_Key_2026_X7m2Q9
VITE_SECURITY_PASSWORD=DepinGuard_Local_UI_Password_2026_N8s3K5

# IoT simulator target
BACKEND_URL=http://localhost:8000

