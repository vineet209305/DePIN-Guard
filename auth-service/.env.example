# ─────────────────────────────────────────────────────────────────────────────
# AUTH SERVICE ENVIRONMENT VARIABLES (Example Template)
# ─────────────────────────────────────────────────────────────────────────────
# WARNING: NEVER commit the actual .env file to GitHub!
# Copy this file to .env and fill in actual values locally only.

# JWT Secret for token signing (change this to a secure random string)
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# Email configuration for sending verification emails
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your-gmail-app-password-not-regular-password

# Note: For Gmail, generate an App Password at https://myaccount.google.com/apppasswords
# Do NOT use your regular Gmail password here
