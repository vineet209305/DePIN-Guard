# DePIN-Guard Backend Environment Variables (Template)
# DO NOT COMMIT REAL VALUES - Use placeholders only
# Real values shared privately with team

# API Security (CHANGE THESE IN PRODUCTION)
DEPIN_API_KEY=your-secure-api-key-256-chars-hex
JWT_SECRET_KEY=your-jwt-secret-key-256-chars-hex

# Service URLs (will be updated after frontend deploy)
AI_SERVICE_URL=http://ai-service:10000/predict
FRONTEND_URL=https://your-frontend.vercel.app

# Blockchain (Azure VM - Update with your actual IP)
BLOCKCHAIN_VM_IP=your-azure-vm-ip
BLOCKCHAIN_ORDERER_HOST=orderer.orderer.depin
BLOCKCHAIN_ORDERER_PORT=7050
FABRIC_ORDERER_ADDRESS=orderer.orderer.depin:7050
FABRIC_PEER1_ADDRESS=peer0.manufacturer.depin:7051
FABRIC_PEER2_ADDRESS=peer0.maintenance.depin:9051

# Database (if using)
DATABASE_URL=sqlite:///./depin.db

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-vercel-frontend.vercel.app

# Server
PORT=8000
HOST=0.0.0.0
DEBUG=False

# AI Service settings
AI_MODEL_PATH=/models
ANOMALY_THRESHOLD=0.7

# Logging
LOG_LEVEL=INFO
