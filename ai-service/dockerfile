FROM python:3.11-slim

WORKDIR /app

# Install dependencies first — separate layer for better Docker cache reuse
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy all remaining service files
COPY . .

# Expose the Flask port
EXPOSE 5000

# Tell Flask which file is the app entry point
ENV FLASK_APP=app.py

# Start Flask — --host=0.0.0.0 makes it reachable outside the container
CMD ["flask", "run", "--host=0.0.0.0", "--port=5000"]